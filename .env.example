# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Backend principal da loja:
# supabase = usa o provider atual do Supabase
# rest = usa sua API propria (ideal para VPS)
# local = usa somente fallbacks locais do projeto
VITE_STORE_BACKEND="supabase"

# API propria da loja (quando VITE_STORE_BACKEND=rest):
# Exemplo local: http://127.0.0.1:4000/api/store
# Exemplo VPS: https://api.sualoja.com/api/store
VITE_API_BASE_URL="http://127.0.0.1:4000/api/store"

# Driver da API REST:
# file = persiste em storage/store-data.json
# mariadb = usa MariaDB/MySQL na sua VPS
STORE_DATA_DRIVER="file"

# Arquivo local usado no modo file
STORE_DATA_FILE_PATH="./storage/store-data.json"

# Porta da API local
STORE_API_PORT="4000"

# CORS da API propria (use * para liberar qualquer origem no inicio)
STORE_API_CORS_ORIGIN="http://127.0.0.1:3000"

# MariaDB / MySQL (necessario apenas quando STORE_DATA_DRIVER=mariadb)
MARIADB_HOST="127.0.0.1"
MARIADB_PORT="3306"
MARIADB_DATABASE="loja"
MARIADB_USER="root"
MARIADB_PASSWORD=""
MARIADB_CONNECTION_LIMIT="10"

# Supabase: usado pelo frontend para carregar catalogo, banners e configuracoes.
VITE_SUPABASE_URL="https://seu-projeto.supabase.co"
VITE_SUPABASE_ANON_KEY="sua-chave-anon-publica"

# Supabase server-side: usado por Vercel Functions / API routes.
# Recomendado para rotas protegidas como /api/keepalive
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"

# Token secreto para proteger /api/keepalive
KEEPALIVE_TOKEN="seu-token-secreto"

# Frete internacional:
# true = tenta buscar cotacoes ao vivo em /api/shipping/quote
# false = forca o fallback para a estimativa local do projeto
VITE_ENABLE_LIVE_SHIPPING="true"

# Shippo (server-side em /api/shipping/quote):
# Defina a chave na Vercel para habilitar tarifas ao vivo no checkout.
# Sem essa chave, o projeto volta automaticamente para a estimativa local.
SHIPPO_API_TOKEN="shippo_live_xxxxxxxxxxxxxxxxx"
# Opcional: mantenha o padrao oficial da API, a menos que a Shippo oriente outro valor.
SHIPPO_API_VERSION="2018-02-08"
