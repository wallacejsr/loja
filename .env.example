# Frontend: all store data is served by the private REST API.
VITE_API_BASE_URL="/api/store"

# Store API
STORE_API_PORT="4000"
STORE_API_CORS_ORIGIN="http://127.0.0.1:3000"
STORE_DATA_DRIVER="mariadb"

# MariaDB
MARIADB_HOST="127.0.0.1"
MARIADB_PORT="3306"
MARIADB_DATABASE="loja"
MARIADB_USER="loja_app"
MARIADB_PASSWORD="change-me"
MARIADB_CONNECTION_LIMIT="10"

# VPS backups
BACKUP_ROOT="/var/backups/zenv-store"
BACKUP_RETENTION_DAYS="14"
BACKUP_UPLOADS_DIR="/home/loja/storage/uploads"
BACKUP_REMOTE_ROOT="gdrive-crypt:ZenvStoreBackups"

# Application
APP_URL="http://127.0.0.1:3000"
APP_SECRETS_ENCRYPTION_KEY="generate-a-long-random-secret"

# Shipping
VITE_ENABLE_LIVE_SHIPPING="true"
SHIPPO_API_TOKEN="shippo_live_xxxxxxxxxxxxxxxxx"
SHIPPO_API_VERSION="2018-02-08"

# Optional AI features
GEMINI_API_KEY=""
